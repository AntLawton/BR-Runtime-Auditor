{
  "name": "br-runtime-auditor",
  "version": "0.1.0",
  "description": "Universal runtime-behaviour verification tool for SST.md-driven products",
  "type": "module",
  "bin": {
    "br-runtime": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-routing-table.mjs",
    "test": "vitest run",
    "lint": "eslint src tests",
    "format": "prettier --check src tests",
    "format:write": "prettier --write src tests"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "3.2.6",
    "yaml": "^2.8.0"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "vitest": "3.2.6",
      "vite": "7.3.5",
      "js-yaml": "4.3.0",
      "brace-expansion@1": "1.1.16",
      "brace-expansion@5": "5.0.7"
    }
  }
}
